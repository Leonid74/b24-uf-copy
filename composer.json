{
    "name": "leonid74/b24-uf-copy",
    "description": "Копирование UF-полей сделок Bitrix24",
    "type": "project",
    "license": "BSD-3-Clause",
    "support": {
        "source": "https://github.com/Leonid74/b24-uf-copy",
        "issues": "https://github.com/Leonid74/b24-uf-copy/issues"
    },
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-phpunit": "^2",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Leonid74\\B24UfCopy\\": "src/Leonid74/B24UfCopy/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Leonid74\\B24UfCopy\\Tests\\": "tests/Leonid74/B24UfCopy/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
